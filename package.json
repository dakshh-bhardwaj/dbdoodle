{
  "name": "dbdoodle",
  "version": "0.0.0",
  "type": "module",
  "description": "AI-powered Visual Database Schema Designer - Design ER diagrams, define tables and relationships manually or via prompts, and share via URL",
  "author": "Dakshh Bhardwaj",
  "repository": {
    "type": "git",
    "url": "https://github.com/dakshh-bhardwaj/dbdoodle",
    "directory": ""
  },
  "bugs": {
    "url": "https://github.com/dakshh-bhardwaj/dbdoodle/issues"
  },
  "keywords": [
    "er-diagram",
    "entity-relationship",
    "database",
    "schema",
    "ai",
    "pwa",
    "sql",
    "postgres",
    "mysql",
    "sqlite",
    "dbdoodle"
  ],
  "scripts": {
    "dev": "vite --open",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,css,html}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "prepare": "husky"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "lz-string": "^1.5.0",
    "node-sql-parser": "^5.4.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "y-protocols": "^1.0.7",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.31",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.0.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "8.0.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,html}": "prettier --write"
  }
}
